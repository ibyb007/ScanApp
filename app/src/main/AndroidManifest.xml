<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to launch the system package installer for the
         auto-downloaded update APK (ACTION_INSTALL_PACKAGE / the
         PackageInstaller session flow). Even with this permission granted,
         Android still shows its own install confirmation screen — this
         permission only lets the app *request* that screen, not skip it. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Only needed on Android 9 (API 28) and below; ML Kit scanner and our
         MediaStore-based save handle Android 10+ without this permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ScanApp"
        android:theme="@style/Theme.ScanApp"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ScanApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Needed if/when you add "Share" for exported files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.scanapp.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
